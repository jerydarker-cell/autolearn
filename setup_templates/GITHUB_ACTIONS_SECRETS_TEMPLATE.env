# Nhập từng key/value này vào GitHub repo → Settings → Secrets and variables → Actions
SUPABASE_URL=CHANGEME_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=CHANGEME_SERVICE_ROLE_KEY
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGEME_EMAIL@gmail.com
SMTP_PASSWORD=CHANGEME_EMAIL_APP_PASSWORD
SMTP_FROM=CHANGEME_EMAIL@gmail.com
TELEGRAM_BOT_TOKEN=
REMINDER_LOOKAHEAD_MIN=15
GOOGLE_API_KEY=
